<?xml version="1.0" encoding="UTF-8"?>
<zabbix_export>
    <version>6.4</version>
    <template_groups>
        <template_group>
            <uuid>7df96b18c230490a9a0a9e2307226338</uuid>
            <name>Templates</name>
        </template_group>
    </template_groups>
    <templates>
        <template>
            <uuid>1d094953acff43a3b7fbf1d153a959d5</uuid>
            <template>Gluster Storage</template>
            <name>Gluster Storage</name>
            <description>## Overview

 This project was created to monitor Gluster Storage with Zabbix. In this repository there are two files. One python script that calls [gstatus](https://github.com/gluster/gstatus), discovering gluster volumes and print data we want, according to the arguments given. You have to install gstatus [gstatus](https://github.com/gluster/gstatus)

* You should save the script in any directory you want, do it executable from zabbix user using sudo.
* You have to create a file in /etc/zabbix/zabbix_agent.d/ and add UserParameters...
* The last one shoud be import zabbix\_template.xml in zabbix

You can check my [github repository](https://github.com/MrCirca/zabbix-glusterfs)
https://github.com/andy0mg/zabbix-glusterfs


## Original Author MrCirca
## Author andy0mg

</description>
            <groups>
                <group>
                    <name>Templates</name>
                </group>
            </groups>
            <items>
                <item>
                    <uuid>331643360a6d443b8fb7d4dd25ea1e17</uuid>
                    <name>Gluster Storage % Free Space</name>
                    <type>CALCULATED</type>
                    <key>gluster_storage_free_space</key>
                    <delay>2m</delay>
                    <units>%</units>
                    <params>100*((last(//gluster_storage_info[&quot;usable_capacity&quot;])-last(//gluster_storage_info[&quot;used_capacity&quot;]))/last(//gluster_storage_info[&quot;usable_capacity&quot;]))</params>
                </item>
                <item>
                    <uuid>4e3b08aea01f45a69d7508cb1ff6808f</uuid>
                    <name>Gluster Storage status</name>
                    <key>gluster_storage_info[&quot;cluster_status&quot;]</key>
                    <delay>2m</delay>
                    <trends>0</trends>
                    <value_type>TEXT</value_type>
                    <triggers>
                        <trigger>
                            <uuid>b947833b77004ddcb925ad050a2b1846</uuid>
                            <expression>find(/Gluster Storage/gluster_storage_info[&quot;cluster_status&quot;],,&quot;like&quot;,&quot;Healthy&quot;)=0</expression>
                            <name>Gluster volume status is Unhealthy</name>
                            <priority>WARNING</priority>
                        </trigger>
                    </triggers>
                </item>
                <item>
                    <uuid>c3c54b8053184534af6c0aa28e05af16</uuid>
                    <name>Gluster Storage Active Nodes</name>
                    <key>gluster_storage_info[&quot;nodes_active&quot;]</key>
                    <delay>2m</delay>
                </item>
                <item>
                    <uuid>45778254ce224773af94ffd22d1542e2</uuid>
                    <name>Gluster Storage Nodes</name>
                    <key>gluster_storage_info[&quot;node_count&quot;]</key>
                    <delay>2m</delay>
                </item>
                <item>
                    <uuid>eeee44efcc9345babd7460f4d5b9c125</uuid>
                    <name>Gluster Storage Volume Number</name>
                    <key>gluster_storage_info[&quot;volume_count&quot;]</key>
                    <delay>2m</delay>
                </item>
                <item>
                    <uuid>dbfcfa8e212b4955a08f03351a45795a</uuid>
                    <name>Gluster Storage Self Heal pending entries</name>
                    <key>gluster_storage_info[heal_entries]</key>
                    <delay>2m</delay>
                    <triggers>
                        <trigger>
                            <uuid>57e6f7c83c9c4cd8ada4c5709e36ed87</uuid>
                            <expression>min(/Gluster Storage/gluster_storage_info[heal_entries],1h)&gt;50
and
nodata(/Gluster Storage/gluster_storage_info[heal_entries],5m)=0</expression>
                            <name>GlusterFS: Self-heal pending entries ({ITEM.LASTVALUE})</name>
                            <priority>HIGH</priority>
                        </trigger>
                        <trigger>
                            <uuid>3d676428925d4de885a0b338ea3a5d5a</uuid>
                            <expression>min(/Gluster Storage/gluster_storage_info[heal_entries],20m)&gt;5</expression>
                            <name>GlusterFS: Self-heal pending entries ({ITEM.LASTVALUE})</name>
                            <priority>WARNING</priority>
                        </trigger>
                    </triggers>
                </item>
                <item>
                    <uuid>b542a7ff79b14d7f9bc8d5f33d5469d0</uuid>
                    <name>GlusterFS: Brick offline</name>
                    <key>gluster_storage_info[online]</key>
                </item>
            </items>
            <discovery_rules>
                <discovery_rule>
                    <uuid>679454c2e7db436fb9adcf1cf50e9f53</uuid>
                    <name>Gluster Volume Names Discovery</name>
                    <key>gluster_volume_name.discovery</key>
                    <delay>30s</delay>
                    <item_prototypes>
                        <item_prototype>
                            <uuid>9c4dda936441448bb2026485eea975a0</uuid>
                            <name>Gluster Volume % Free Space {#VOLUME_NAME}</name>
                            <type>CALCULATED</type>
                            <key>gluster_volume_free_space[{#VOLUME_NAME}]</key>
                            <delay>30s</delay>
                            <units>%</units>
                            <params>100*((last(//gluster_volume_info[&quot;size_total&quot;,{#VOLUME_NAME}])-last(//gluster_volume_info[&quot;size_used&quot;,{#VOLUME_NAME}]))/last(//gluster_volume_info[&quot;size_total&quot;,{#VOLUME_NAME}]))</params>
                            <trigger_prototypes>
                                <trigger_prototype>
                                    <uuid>fe47c683552d489eba3f26f8ee836842</uuid>
                                    <expression>last(/Gluster Storage/gluster_volume_free_space[{#VOLUME_NAME}],#1:now-5m)&lt;20</expression>
                                    <name>Gluster Volume Free Space is less than 20%</name>
                                    <priority>WARNING</priority>
                                </trigger_prototype>
                            </trigger_prototypes>
                        </item_prototype>
                        <item_prototype>
                            <uuid>3bf1fc8ff3ad4e10b84097caf5a56518</uuid>
                            <name>Gluster Volume state on {#VOLUME_NAME}</name>
                            <key>gluster_volume_info[&quot;health&quot;,{#VOLUME_NAME}]</key>
                            <delay>30s</delay>
                            <trends>0</trends>
                            <value_type>TEXT</value_type>
                            <trigger_prototypes>
                                <trigger_prototype>
                                    <uuid>b719e8cf2b304242a4ed054886a04b70</uuid>
                                    <expression>find(/Gluster Storage/gluster_volume_info[&quot;health&quot;,{#VOLUME_NAME}],,&quot;regexp&quot;,&quot;^up$&quot;)=0</expression>
                                    <name>Gluster Volume state in {#VOLUME_NAME} is down</name>
                                    <priority>WARNING</priority>
                                </trigger_prototype>
                            </trigger_prototypes>
                        </item_prototype>
                        <item_prototype>
                            <uuid>2242d2c02a3644c994dbc9d300abe5f8</uuid>
                            <name>Gluster Volume Total Size on {#VOLUME_NAME}</name>
                            <key>gluster_volume_info[&quot;size_total&quot;,{#VOLUME_NAME}]</key>
                            <delay>30s</delay>
                            <units>b</units>
                        </item_prototype>
                        <item_prototype>
                            <uuid>bc2ca197dc7642e99334b67cd58142ee</uuid>
                            <name>Gluster Volume Used Size on {#VOLUME_NAME}</name>
                            <key>gluster_volume_info[&quot;size_used&quot;,{#VOLUME_NAME}]</key>
                            <delay>30s</delay>
                            <units>b</units>
                        </item_prototype>
                        <item_prototype>
                            <uuid>f917a8279c574070b98b95bab6751622</uuid>
                            <name>GlusterFS: Total bricks [{#VOLUME_NAME}]</name>
                            <key>gluster_volume_info[num_bricks,&quot;{#VOLUME_NAME}&quot;]</key>
                        </item_prototype>
                        <item_prototype>
                            <uuid>3e563a2ad0744dd3be6bb1fb330ff95f</uuid>
                            <name>GlusterFS: Online bricks [{#VOLUME_NAME}]</name>
                            <key>gluster_volume_info[online,&quot;{#VOLUME_NAME}&quot;]</key>
                        </item_prototype>
                        <item_prototype>
                            <uuid>3916a58d3d0a44918ef88b9242b3ebcf</uuid>
                            <name>GlusterFS: Volume status [{#VOLUME_NAME}]</name>
                            <key>gluster_volume_info[status,&quot;{#VOLUME_NAME}&quot;]</key>
                            <trends>0</trends>
                            <value_type>TEXT</value_type>
                        </item_prototype>
                    </item_prototypes>
                    <trigger_prototypes>
                        <trigger_prototype>
                            <uuid>2c60b996502647948c245ee7a556c225</uuid>
                            <expression>last(/Gluster Storage/gluster_volume_info[online,&quot;{#VOLUME_NAME}&quot;])
&lt;
last(/Gluster Storage/gluster_volume_info[num_bricks,&quot;{#VOLUME_NAME}&quot;])</expression>
                            <name>GlusterFS: Volume {#VOLUME_NAME} has offline bricks</name>
                        </trigger_prototype>
                    </trigger_prototypes>
                </discovery_rule>
            </discovery_rules>
        </template>
    </templates>
    <triggers>
        <trigger>
            <uuid>8e4d5a0b0cd2465891477af77f34a002</uuid>
            <expression>last(/Gluster Storage/gluster_storage_info[&quot;nodes_active&quot;]) &lt; last(/Gluster Storage/gluster_storage_info[&quot;node_count&quot;])</expression>
            <name>Gluster storage nodes is not online</name>
            <priority>INFO</priority>
        </trigger>
    </triggers>
</zabbix_export>
